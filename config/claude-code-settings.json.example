{
  "mcpServers": {
    "autotask-mcp": {
      "command": "autotask-mcp",
      "env": {
        "AUTOTASK_USERNAME": "api-user@company.com",
        "AUTOTASK_SECRET": "your-api-secret",
        "AUTOTASK_INTEGRATION_CODE": "your-integration-code"
      }
    },
    "itglue-mcp": {
      "command": "itglue-mcp",
      "env": {
        "ITGLUE_API_KEY": "ITG.your-api-key",
        "ITGLUE_REGION": "eu"
      }
    },
    "datto-rmm-mcp": {
      "command": "datto-rmm-mcp",
      "env": {
        "DATTO_API_KEY": "your-api-key",
        "DATTO_API_SECRET": "your-api-secret",
        "DATTO_PLATFORM": "merlot"
      }
    },
    "rocketcyber-mcp": {
      "command": "rocketcyber-mcp",
      "env": {
        "ROCKETCYBER_API_KEY": "your-api-key",
        "ROCKETCYBER_REGION": "eu"
      }
    },
    "datto-uc-mcp": {
      "command": "datto-uc-mcp",
      "env": {
        "DATTO_UC_PUBLIC_KEY": "your-public-key",
        "DATTO_UC_SECRET_KEY": "your-secret-key"
      }
    },
    "datto-edr-mcp": {
      "command": "datto-edr-mcp",
      "env": {
        "DATTO_EDR_API_KEY": "your-access-token",
        "DATTO_EDR_BASE_URL": "https://yourorg.infocyte.com"
      }
    },
    "datto-backup-mcp": {
      "command": "datto-backup-mcp",
      "env": {
        "DATTO_BACKUP_CLIENT_ID": "your-client-id",
        "DATTO_BACKUP_CLIENT_SECRET": "your-client-secret"
      }
    },
    "datto-network-mcp": {
      "command": "datto-network-mcp",
      "env": {
        "DATTO_NETWORK_PUBLIC_KEY": "your-public-key",
        "DATTO_NETWORK_SECRET_KEY": "your-secret-key"
      }
    },
    "myitprocess-mcp": {
      "command": "myitprocess-mcp",
      "env": {
        "MYITPROCESS_API_KEY": "your-api-key"
      }
    }
  }
}
